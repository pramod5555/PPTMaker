# Copy this file to .env and fill in your values.
# .env is gitignored — never commit the actual keys.

# ── Paths ──────────────────────────────────────────────────────────────────────
POPPLER_PATH=C:\path\to\poppler\bin

# ── Azure OpenAI ───────────────────────────────────────────────────────────────
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=https://<your-resource>.cognitiveservices.azure.com/
AZURE_OPENAI_API_VERSION=2024-12-01-preview

# Full model — used for slide generation and converter.py
AZURE_OPENAI_DEPLOYMENT=gpt-5.4

# Mini model — used for generate_training.py (cheaper, faster for bulk pair generation)
AZURE_OPENAI_MINI_DEPLOYMENT=gpt-5.4-mini
AZURE_OPENAI_MINI_API_KEY=

# ── Anthropic (optional) ───────────────────────────────────────────────────────
ANTHROPIC_API_KEY=
